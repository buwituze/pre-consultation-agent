# Database Config
# ⚠️ CRITICAL: Database must be running and accessible
# If not configured, /kiosk endpoints will return 503
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pre_consultation_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Enable/disable database (set to 'false' for testing without database)
USE_DB=true

# API Config
API_HOST=0.0.0.0
API_PORT=8000

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-this-in-production-use-long-random-string

# Audio Storage
AUDIO_STORAGE_DIR=data/audio

# ML Model Config
MODEL_VERSION=v1.0.0
MODEL_PATH=../model/
MAX_TURNS=6

# Hugging Face Token (for Whisper model access)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Model Inference Device
# Use 'cuda' if GPU available (MUCH faster - transcription ~10x quicker)
# Use 'cpu' otherwise (Whisper large-v3 can take 2-4 min per 30s audio on CPU)
DEVICE=cpu

# Skip language detection when user selected Kinyarwanda/English (saves ~30-60s on CPU)
# Set to 'true' for faster demos when patient always selects language on screen
SKIP_LANG_DETECTION_WHEN_HINTED=false

# Google Gemini API (for Model B, C, D, E, F)
GOOGLE_API_KEY=your_google_api_key_here

# Logging
LOG_LEVEL=INFO
