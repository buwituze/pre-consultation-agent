# Database Config
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pre_consultation_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# API Config
API_HOST=0.0.0.0
API_PORT=8000

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-change-this-in-production-use-long-random-string

# Audio Storage
AUDIO_STORAGE_DIR=data/audio

# ML Model Config
MODEL_VERSION=v1.0.0
MODEL_PATH=../model/
MAX_TURNS=6

# Google Gemini API (for Model B, C, D, E, F)
GOOGLE_API_KEY=your_google_api_key_here

# Logging
LOG_LEVEL=INFO
